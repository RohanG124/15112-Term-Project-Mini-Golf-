def onMousePress(app,mouseX, mouseY):
    if(app.menu):
        if(mouseX >= 300 and mouseX <= 400 and mouseY >= 363 and mouseY <= 438):
            app.menu = False
        return
    
    if(app.playButton):#course selection on start screen
        if(dist(mouseX, mouseY, 117, 390) <= 50):
            app.playButton = False
            app.currentCourse = app.course1
        if(dist(mouseX, mouseY, 233, 390) <= 50):
            app.playButton = False
            app.currentCourse = app.course2
        if(dist(mouseX, mouseY, 350, 390) <= 50):
            app.playButton = False
            app.currentCourse = app.course3
        if(dist(mouseX, mouseY, 467, 390) <= 50):
            app.playButton = False
            app.currentCourse = app.course4
        if(dist(mouseX, mouseY, 583, 390) <= 50):
            app.playButton = False
            app.currentCourse = app.course5
        reset(app)
        return
    
    if(mouseX >= 602 and mouseY <= 65):
        app.help = not app.help
    
    if(app.help):
        return
    
    app.initialPress = dist(mouseX, mouseY, app.ball.x, app.ball.y)

    #course selection on game screens
    if(dist(mouseX, mouseY, 20, 20) <= 15):
        app.currentCourse = app.course1
        reset(app)
    if(dist(mouseX, mouseY, 20, 55) <= 15):
        app.currentCourse = app.course2
        reset(app)
    if(dist(mouseX, mouseY, 20, 90) <= 15):
        app.currentCourse = app.course3
        reset(app)
    if(dist(mouseX, mouseY, 20, 125) <= 15):
        app.currentCourse = app.course4
        reset(app)
    if(dist(mouseX, mouseY, 20, 160) <= 15):
        app.currentCourse = app.course5
        reset(app)
    
def onMouseDrag(app, mouseX, mouseY):
    if(app.menu or app.playButton or app.help or app.win):
        return
    if(app.initialPress <= 5):
        power = dist(mouseX, mouseY, app.ball.x, app.ball.y)
        app.PowerLine = True
        app.PowerLineX = mouseX
        app.PowerLineY = mouseY
        if(power <= 50):
            app.PowerLineColor = 'green'
        elif(power <= 100):
            app.PowerLineColor = 'yellow'
        else:
            app.PowerLineColor = 'red'

def onMouseRelease(app, mouseX, mouseY):
    if(app.PowerLine == True):
        app.hits += 1
        app.ball.vx = (app.ball.x - mouseX) * 0.1 #same vector, scaled down to fit 60 fps
        app.ball.vy = (app.ball.y - mouseY) * 0.1
        power = (app.ball.vx**2 + app.ball.vy**2)**0.5
        while(power > 15):
            scaleDown = power - 0.5
            app.ball.vx *= scaleDown/power
            app.ball.vy *= scaleDown/power
            power = scaleDown
    app.PowerLine = False

def onStep(app):
    if(app.menu):
        if app.totalSteps/60 >= 3:
            app.playButton = True
        app.totalSteps += 1
        return
    if(app.playButton):
        app.totalSteps += 1
        if(app.totalSteps % 2 == 0):
            app.animBallx += 5
        if(app.animBallx >= 520):
            app.animBallx=160
        return
    
    #split changing for account for tunneling
    for i in range(10):
        for wall in app.currentCourse.lines:
            reflectWalls(app, wall)
        if(dist(app.ball.x, app.ball.y, app.currentCourse.hole[0], app.currentCourse.hole[1]) <= 7.5):
            app.win = True
        app.ball.x += app.ball.vx/10
        app.ball.y += app.ball.vy/10
        applyObstacles(app)
    
    #wind application
    if(app.wind):
        angle = math.radians(app.windAngle)
        windX = 0.02*app.windSpeed * math.cos(angle)
        windY = 0.02*app.windSpeed * math.sin(angle)
        app.ball.vx += windX
        app.ball.vy += windY
    
    #This section of code is from ChatGPT. This code is fully created by AI
    speed = (app.ball.vx**2 + app.ball.vy**2)**0.5
    if(speed > 0):
        nextSpeed = speed - app.friction
        if(nextSpeed < 0):
            app.ball.vx = 0
            app.ball.vy = 0
        else:
            app.ball.vx *= (nextSpeed/speed)
            app.ball.vy *= (nextSpeed/speed)
    #end of AI section
    
def applyObstacles(app):
    for obstacle in app.currentCourse.obstacles:
        #bouncy circle
        if(type(obstacle[0]) == int):
            if(dist(app.ball.x, app.ball.y, obstacle[0], obstacle[1]) <= 5 + obstacle[2]):
                dx = app.ball.x - obstacle[0]
                dy = app.ball.y - obstacle[1]
                centerX = app.ball.x
                centerY = app.ball.y
                nx = -dy
                ny = dx
                wall = [centerX - nx, centerY - ny, centerX + nx, centerY + ny]
                reflectWalls(app, wall)
                magnitude = (app.ball.vx**2 + app.ball.vy**2)**0.5
                if(magnitude != 0):
                    app.ball.vx *= (10/magnitude)
                    app.ball.vy *= (10/magnitude)
        #slope
        else:
            if(app.ball.x >= obstacle[0][0] and app.ball.x <= obstacle[0][2] and app.ball.y >= obstacle[0][1] and app.ball.y <= obstacle[0][3]):
                app.ball.vx += 0.0175 * obstacle[1][0]
                app.ball.vy += 0.0175 * obstacle[1][1]

def reflectWalls(app, wall):
    x1, y1, x2, y2 = wall
    dx = x2 - x1
    dy = y2 - y1
    length = (dx**2 + dy**2)**0.5
    #for figuring out closest point of ball-to-line
    projection = ((app.ball.x - x1)*dx + (app.ball.y - y1)*dy) / (length)**2
    projection = max(0, min(1, projection))
    xOnLine = x1 + projection*dx
    yOnLine = y1 + projection*dy
    distance = dist(app.ball.x, app.ball.y, xOnLine, yOnLine)
    if(distance <= 5):
        #reflection formula: r= v - 2(v dot n)n
        nx = -dy
        ny = dx
        magnitude = (nx**2 + ny**2)**0.5
        nx /= magnitude
        ny /= magnitude
        # Start of AI section, from ChatGPT. This section is fully created by AI
        if(app.ball.vx*nx + app.ball.vy*ny > 0):
            nx *= -1
            ny *= -1
        # End of AI section
        dot = app.ball.vx*nx + app.ball.vy*ny
        app.ball.vx -= 2 * dot * nx
        app.ball.vy -= 2 * dot * ny
        app.ball.x += nx*4
        app.ball.y += ny*4

def dist(x1, y1, x2, y2):
    return ((x1-x2)**2 + (y1-y2)**2)**0.5

class Ball:
    def __init__(self, x, y, vx, vy):
        self.x = x
        self.y = y
        self.vx = vx
        self.vy = vy

