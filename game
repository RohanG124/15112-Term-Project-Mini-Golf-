def reset(app):
    app.totalSteps = 0
    app.help = False
    app.win = False
    app.hits = 0
    
    app.wind = False
    app.windSpeed = random.randint(1, 5)
    if(app.menu == False):
        windExists = random.randint(1, 10)
        if(windExists <= 7):
            app.wind = True
        else:
            app.wind = False
        app.windSpeed = random.randint(1, 5)
    app.windAngle = random.randint(0, 360)
    resetBall(app)

def resetBall(app):
    app.ball.x = app.currentCourse.startx
    app.ball.y = app.currentCourse.starty
    app.ball.vx = 0
    app.ball.vy = 0

