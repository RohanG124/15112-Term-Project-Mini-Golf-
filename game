def drawFlag(x, y, angle):
    length = 80
    angle *= (math.pi/180)
    x1 = math.cos(-angle)*length+x
    y1 = math.sin(-angle)*length+y
    tipX = math.cos(-angle-math.pi/7)*(length-15) + x
    tipY = math.sin(-angle-math.pi/7)*(length-15) + y
    x2 = math.cos(-angle) * (length-30) + x
    y2 = math.sin(-angle) * (length-30) + y
    drawPolygon(x1, y1, tipX, tipY, x2, y2, fill='red', border='black')
    drawLine(x, y, x1, y1, fill=rgb(250, 250, 250), lineWidth=7)
    
